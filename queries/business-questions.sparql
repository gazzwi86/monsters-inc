# =============================================================================
# Monsters, Inc. — Business Questions SPARQL Queries
# Base ontology: https://vocab.monstersinc.com/ontology#
# Each query is standalone with full PREFIX declarations.
# =============================================================================


# Q1: Top 10 comedians by energy yield this month
# Business question: Who are the highest-producing comedians this month?
# Returns: comedian name, cert level, total MWh, ranked by descending yield

PREFIX mi:  <https://vocab.monstersinc.com/ontology#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

SELECT ?name ?certLevel (SUM(?mwh) AS ?totalMWh)
WHERE {
    ?comedian a mi:Comedian ;
              mi:name ?name ;
              mi:certLevel ?certLevel .
    ?record a mi:PerformanceRecord ;
            mi:comedian ?comedian ;
            mi:date ?date ;
            mi:energyGenerated ?mwh .
    FILTER (MONTH(?date) = MONTH(NOW()) && YEAR(?date) = YEAR(NOW()))
}
GROUP BY ?comedian ?name ?certLevel
ORDER BY DESC(?totalMWh)
LIMIT 10


# Q2: Overdue doors and the operations they impact
# Business question: Which active child doors are past their 180-day maintenance
#   window, and which station / comedian does each currently serve?
# Returns: portal code, last maintained date, impacted station, assigned comedian
# Operational view — distinct from CV2, which is the bare compliance violation list.

PREFIX mi:   <https://vocab.monstersinc.com/ontology#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX xsd:  <http://www.w3.org/2001/XMLSchema#>

SELECT (STR(?portalCode) AS ?portalCode) (STR(?lastMaintained) AS ?lastMaintainedDate)
       ?stationId ?comedianName
WHERE {
    ?door a mi:ChildDoor ;
          mi:portalCode ?portalCode ;
          mi:doorStatus mi:active ;
          mi:lastMaintained ?lastMaintained .
    FILTER (xsd:dateTime(CONCAT(STR(?lastMaintained), "T00:00:00Z")) < (NOW() - "P180D"^^xsd:duration))
    OPTIONAL {
        ?station mi:activeDoor ?door ; mi:stationId ?stationId .
        OPTIONAL { ?station mi:assignedComedian ?c . ?c mi:name ?comedianName }
    }
}
ORDER BY ASC(?lastMaintained)


# Q3: CDA incidents per quarter (last 4 quarters)
# Business question: How many CDA incidents occurred each quarter?
# Returns: year, quarter (1–4), incident count

PREFIX mi:  <https://vocab.monstersinc.com/ontology#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

SELECT ?year ?quarter (COUNT(?incident) AS ?incidentCount)
WHERE {
    ?incident a mi:CDAIncident ;
              mi:detectedAt ?detectedAt .
    BIND(YEAR(?detectedAt) AS ?year)
    BIND((FLOOR((MONTH(?detectedAt) - 1) / 3) + 1) AS ?quarter)
    FILTER (?detectedAt >= (NOW() - "P365D"^^xsd:duration))
}
GROUP BY ?year ?quarter
ORDER BY ASC(?year) ASC(?quarter)


# Q4: Average laugh-to-energy conversion rate by comedian certification level
# Business question: Do higher-certified comedians convert laughter to energy more efficiently?
# Returns: cert level, average conversion rate (MWh per laugh unit)

PREFIX mi:  <https://vocab.monstersinc.com/ontology#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

SELECT ?certLevel (AVG(?conversionRate) AS ?avgConversionRate)
WHERE {
    ?comedian a mi:Comedian ;
              mi:certLevel ?certLevel .
    ?record a mi:PerformanceRecord ;
            mi:comedian ?comedian ;
            mi:laughScore ?laughScore ;
            mi:energyGenerated ?energyGenerated .
    FILTER (?laughScore > 0)
    BIND((?energyGenerated / ?laughScore) AS ?conversionRate)
}
GROUP BY ?certLevel
ORDER BY ASC(?certLevel)


# Q5: Training certifications expiring in the next 30 days
# Business question: Which comedians need to renew certifications urgently?
# Returns: comedian name, cert level, training record, expiry date

PREFIX mi:  <https://vocab.monstersinc.com/ontology#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

SELECT ?comedianName ?certLevel ?trainingRecord ?expiresAt
WHERE {
    ?comedian a mi:Comedian ;
              mi:name ?comedianName ;
              mi:certLevel ?certLevel .
    ?trainingRecord a mi:TrainingRecord ;
                    mi:trainee ?comedian ;
                    mi:expiresAt ?expiresAt .
    BIND(xsd:dateTime(CONCAT(STR(?expiresAt), "T00:00:00Z")) AS ?expDateTime)
    FILTER (?expDateTime > NOW())
    FILTER (?expDateTime <= (NOW() + "P30D"^^xsd:duration))
}
ORDER BY ASC(?expiresAt)


# Q6: Monthly energy production trend (last 12 months, MWh)
# Business question: What is the month-by-month energy output trajectory?
# Returns: year, month, total MWh produced

PREFIX mi:  <https://vocab.monstersinc.com/ontology#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

SELECT ?year ?month (SUM(?mwh) AS ?totalMWh)
WHERE {
    ?record a mi:PerformanceRecord ;
            mi:date ?date ;
            mi:energyGenerated ?mwh .
    BIND(YEAR(?date)  AS ?year)
    BIND(MONTH(?date) AS ?month)
    FILTER (xsd:dateTime(CONCAT(STR(?date), "T00:00:00Z")) >= (NOW() - "P365D"^^xsd:duration))
}
GROUP BY ?year ?month
ORDER BY ASC(?year) ASC(?month)


# Q7: Child profiles assigned to more than one door (data integrity check)
# Business question: Are there duplicate door-to-child-profile assignments?
# Returns: child profile URI, count of doors assigned

PREFIX mi:  <https://vocab.monstersinc.com/ontology#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

SELECT ?childProfile (COUNT(?door) AS ?doorCount)
WHERE {
    ?door a mi:ChildDoor ;
          mi:childProfile ?childProfile .
}
GROUP BY ?childProfile
HAVING (COUNT(?door) > 1)
ORDER BY DESC(?doorCount)


# Q8: Full PROV-O lineage chain for a given EnergyUnit
# Business question: What is the complete provenance chain from laugh to grid energy?
# Returns: energy unit, source canister, derived laugh canister, laugh activity,
#          associated comedian, station, and door
# Note: Requires mi-provenance.ttl to be loaded into the graph.

PREFIX mi:   <https://vocab.monstersinc.com/ontology#>
PREFIX prov: <http://www.w3.org/ns/prov#>
PREFIX xsd:  <http://www.w3.org/2001/XMLSchema#>

SELECT ?energyUnit ?sourceCanister ?sealingActivity ?comedian ?station ?door
WHERE {
    ?energyUnit a mi:EnergyUnit ;
                prov:wasDerivedFrom ?sourceCanister .
    ?sourceCanister a mi:LaughCanister .
    OPTIONAL {
        ?sealingActivity a prov:Activity ;
                       prov:generated ?sourceCanister .
        OPTIONAL { ?sealingActivity prov:wasAssociatedWith ?comedian .
                   ?comedian a mi:Comedian . }
        OPTIONAL { ?sealingActivity prov:wasAssociatedWith ?station .
                   ?station a mi:LaughFloorStation . }
        OPTIONAL { ?sealingActivity prov:wasAssociatedWith ?door .
                   ?door a mi:ChildDoor . }
    }
}
ORDER BY ?energyUnit


# Q9: Shared child profiles — full door and profile detail
# Business question: Which child profiles span more than one door, and what do we know about them?
# Returns: one row per door assignment — portal code, door status, profile attributes, total door count
# Note: shared-profile-001 has intentionally inconsistent ageRange/timezone values (data quality anomaly)

PREFIX mi: <https://vocab.monstersinc.com/ontology#>

# One row PER DOOR. The shared profile deliberately carries inconsistent
# attribute values (a data-quality anomaly); GROUP_CONCAT collapses those into
# one cell per door instead of an OPTIONAL cross-product (which produced 36 rows).
SELECT (STRAFTER(STR(?childProfile), "/profile/") AS ?profileId) ?portalCode ?doorStatus
       (GROUP_CONCAT(DISTINCT ?ar; SEPARATOR=" | ") AS ?ageRanges)
       (GROUP_CONCAT(DISTINCT ?bt; SEPARATOR=" | ") AS ?bedroomTypes)
       (GROUP_CONCAT(DISTINCT ?tz; SEPARATOR=" | ") AS ?timezones)
       ?totalDoors
WHERE {
    {
        SELECT ?childProfile (COUNT(?d) AS ?totalDoors)
        WHERE {
            ?d a mi:ChildDoor ;
               mi:childProfile ?childProfile .
        }
        GROUP BY ?childProfile
        HAVING (COUNT(?d) > 1)
    }
    ?door a mi:ChildDoor ;
          mi:childProfile ?childProfile ;
          mi:portalCode ?portalCode ;
          mi:doorStatus ?rawStatus .
    BIND(STRAFTER(STR(?rawStatus), "#") AS ?doorStatus)
    OPTIONAL { ?childProfile mi:ageRange ?ar }
    OPTIONAL { ?childProfile mi:bedroomType ?bt }
    OPTIONAL { ?childProfile mi:timezone ?tz }
}
GROUP BY ?childProfile ?portalCode ?doorStatus ?totalDoors
ORDER BY ?childProfile ?portalCode


# Q10: Live Laugh Floor map — comedian, station, and active door
# Business question: What is the current operational layout of the Laugh Floor?
# Returns: station ID, comedian name, cert level, current laugh score, portal code, door status

PREFIX mi: <https://vocab.monstersinc.com/ontology#>

SELECT ?stationId ?comedianName ?certLevel ?currentLaughScore ?portalCode ?doorStatus
WHERE {
    ?station a mi:LaughFloorStation ;
             mi:stationId ?stationId ;
             mi:assignedComedian ?comedian .
    ?comedian a mi:Comedian ;
              mi:name ?comedianName ;
              mi:certLevel ?certLevel ;
              mi:currentLaughScore ?currentLaughScore .
    OPTIONAL {
        ?station mi:activeDoor ?door .
        ?door mi:portalCode ?portalCode ;
              mi:doorStatus ?rawStatus .
        BIND(STRAFTER(STR(?rawStatus), "#") AS ?doorStatus)
    }
}
ORDER BY ?stationId


# Q11: Idle stations — comedians on duty without an active door assigned
# Business question: Which laugh floor stations are staffed but have no door active?
# Returns: station ID, comedian name, cert level, shift — these stations contribute zero energy

PREFIX mi: <https://vocab.monstersinc.com/ontology#>

SELECT ?stationId ?comedianName ?certLevel (STRAFTER(STR(?shift), "#") AS ?shift)
WHERE {
    ?station a mi:LaughFloorStation ;
             mi:stationId ?stationId ;
             mi:shift ?shift ;
             mi:assignedComedian ?comedian .
    ?comedian a mi:Comedian ;
              mi:name ?comedianName ;
              mi:certLevel ?certLevel .
    FILTER NOT EXISTS { ?station mi:activeDoor ?door }
}
ORDER BY ?stationId


# Q12: Door status inventory — count of doors by operational status
# Business question: How many doors are in each status category right now?
# Returns: status label, count — active/maintenance/quarantined/decommissioned breakdown

PREFIX mi: <https://vocab.monstersinc.com/ontology#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT (STRAFTER(STR(?rawStatus), "#") AS ?doorStatus) (COUNT(?door) AS ?doorCount)
WHERE {
    ?door a mi:ChildDoor ;
          mi:doorStatus ?rawStatus .
}
GROUP BY ?rawStatus
ORDER BY DESC(?doorCount)


# Q13: Comedian laugh score drift — current score vs historical performance average
# Business question: Which comedians are trending above or below their own historical baseline?
# Returns: comedian name, cert level, current live score, historical average, drift (positive = improving)

PREFIX mi: <https://vocab.monstersinc.com/ontology#>

SELECT ?comedianName ?certLevel ?currentLaughScore
       (ROUND(AVG(?recordedScore) * 100) / 100 AS ?avgHistoricalScore)
       (ROUND((?currentLaughScore - AVG(?recordedScore)) * 100) / 100 AS ?scoreDrift)
WHERE {
    ?comedian a mi:Comedian ;
              mi:name ?comedianName ;
              mi:certLevel ?certLevel ;
              mi:currentLaughScore ?currentLaughScore .
    ?record a mi:PerformanceRecord ;
            mi:comedian ?comedian ;
            mi:laughScore ?recordedScore .
}
GROUP BY ?comedian ?comedianName ?certLevel ?currentLaughScore
ORDER BY ASC(?scoreDrift)


# Q14: Comedians with no performance records on file
# Business question: Are there active comedians who have never had a performance logged?
# Returns: employee ID, name, cert level, current laugh score — expected 0 rows confirms 100% coverage

PREFIX mi: <https://vocab.monstersinc.com/ontology#>

SELECT ?employeeId ?comedianName ?certLevel ?currentLaughScore
WHERE {
    ?comedian a mi:Comedian ;
              mi:employeeId ?employeeId ;
              mi:name ?comedianName ;
              mi:certLevel ?certLevel .
    OPTIONAL { ?comedian mi:currentLaughScore ?currentLaughScore }
    FILTER NOT EXISTS {
        ?record a mi:PerformanceRecord ;
                mi:comedian ?comedian .
    }
}
ORDER BY ?employeeId


# Q15: Direct reports to the CEO — first-level organisational hierarchy
# Business question: Who are the direct reports to James P. Sullivan, and what domains do they own?
# Returns: employee ID, name, title role, department — the executive team reporting line

PREFIX mi: <https://vocab.monstersinc.com/ontology#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT ?employeeId ?name
       (STRAFTER(STR(?rawRole), "#") AS ?titleRole)
       (STRAFTER(STR(?rawDept), "#") AS ?domain)
WHERE {
    ?employee mi:reportsTo <https://vocab.monstersinc.com/comedian/emp-001> ;
              mi:name ?name ;
              mi:employeeId ?employeeId .
    OPTIONAL { ?employee mi:holdsTitleRole ?rawRole }
    OPTIONAL { ?employee mi:department ?rawDept }
}
ORDER BY ?employeeId


# Q16: Strategy traceability — goal → capability → process → owning domain
# Business question: For each strategic goal, which capabilities serve it, which
#   business processes realise those capabilities, and which domain owns them?
# Returns: goal, capability, realising process, owning domain
# Demonstrates the strategy→capability→process chain is connected in RDF, not
# just prose — an agent can reason from intent down to execution.

PREFIX mi:   <https://vocab.monstersinc.com/ontology#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT ?goal ?capability ?process (STRAFTER(STR(?domain), "#") AS ?owningDomain)
WHERE {
    ?cap a mi:Capability ;
         rdfs:label ?capability ;
         mi:servesGoal ?g ;
         mi:ownedByDomain ?domain .
    ?g rdfs:label ?goal .
    ?proc a mi:BusinessProcess ;
          rdfs:label ?process ;
          mi:realizesCapability ?cap .
}
ORDER BY ?goal ?capability


# Q17: R&D pipeline — laughter-technique prototypes by status and target yield
# Business question: What is in the R&D pipeline, at what stage, and which
#   prototype promises the highest energy yield?
# Returns: prototype technique, lifecycle status, target yield (MWh), notes
# Wires the D6 R&D domain (mi:RDPrototype) into the queryable graph.

PREFIX mi:   <https://vocab.monstersinc.com/ontology#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX xsd:  <http://www.w3.org/2001/XMLSchema#>

SELECT (STR(?technique) AS ?prototype) (REPLACE(STR(?status), "^.*[#/]", "") AS ?status)
       ?yieldTarget (STR(?notes) AS ?testResults)
WHERE {
    ?p a mi:RDPrototype ;
       mi:technique  ?technique ;
       mi:status     ?status ;
       mi:yieldTarget ?yieldTarget ;
       mi:testResults ?notes .
}
ORDER BY DESC(?yieldTarget)


# Q18: Energy-era transition — canisters by class and energy type
# Business question: How does the fleet split between the legacy scream-energy
#   era and the current laughter era? (The scare→laughter pivot, made queryable.)
# Returns: canister class, energy type, count
# Matches the Canister superclass via subClassOf* (run_queries does no inference).

PREFIX mi:   <https://vocab.monstersinc.com/ontology#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT (REPLACE(STR(?cls), "^.*[#/]", "") AS ?canisterClass)
       (REPLACE(STR(?et), "^.*[#/]", "") AS ?energyType)
       (COUNT(?c) AS ?count)
WHERE {
    ?c a ?cls .
    ?cls rdfs:subClassOf* mi:Canister .
    OPTIONAL { ?c mi:energyType ?et }
}
GROUP BY ?cls ?et
ORDER BY ?canisterClass


# Q19: Station throughput — busiest Laugh Floor stations by output
# Business question: Which stations carry the most performances, and how much
#   energy does each generate in total?
# Returns: station ID, performance count, total energy generated (MWh), avg per session
# Exploits mi:atStation on every PerformanceRecord — surfaces load concentration
# across the floor, distinct from Q10's live snapshot (this aggregates history).

PREFIX mi:   <https://vocab.monstersinc.com/ontology#>
PREFIX xsd:  <http://www.w3.org/2001/XMLSchema#>

SELECT ?stationId (COUNT(?record) AS ?performanceCount)
       (ROUND(SUM(?mwh) * 100) / 100 AS ?totalMWh)
       (ROUND(AVG(?mwh) * 100) / 100 AS ?avgMWhPerSession)
WHERE {
    ?record a mi:PerformanceRecord ;
            mi:atStation ?station ;
            mi:energyGenerated ?mwh .
    ?station mi:stationId ?stationId .
}
GROUP BY ?station ?stationId
ORDER BY DESC(?totalMWh)


# Q20: Training-programme coverage — enrolment per programme
# Business question: How many monsters have a training record against each
#   formal TrainingProgram, and how many of those certifications are still valid?
# Returns: programme label, total enrolments, still-valid certifications
# Exploits mi:program on every TrainingRecord — turns the programme catalogue
# into a coverage report, complementing Q5 (urgent renewals, individual grain).

PREFIX mi:   <https://vocab.monstersinc.com/ontology#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX xsd:  <http://www.w3.org/2001/XMLSchema#>

SELECT ?programme (COUNT(?record) AS ?enrolments)
       (SUM(IF(?valid, 1, 0)) AS ?currentlyValid)
WHERE {
    ?record a mi:TrainingRecord ;
            mi:program ?prog .
    ?prog rdfs:label ?programme .
    OPTIONAL { ?record mi:expiresAt ?expiresAt }
    BIND(BOUND(?expiresAt) &&
         xsd:dateTime(CONCAT(STR(?expiresAt), "T00:00:00Z")) > NOW() AS ?valid)
}
GROUP BY ?prog ?programme
ORDER BY DESC(?enrolments)


# Q21: Door-technician span of control — managed doors vs active fleet
# Business question: How many doors does each door technician manage, and what
#   share of the active-door fleet does the technician corps cover?
# Returns: technician name, clearance level, doors managed, share of active fleet (%)
# Exploits mi:doorsManaged on DoorTechnician. NB seed assigns every technician the
# same nominal load (40), so the ranking is flat by design — the analytical value
# is the coverage ratio: total managed capacity against the live active-door count.

PREFIX mi:   <https://vocab.monstersinc.com/ontology#>
PREFIX xsd:  <http://www.w3.org/2001/XMLSchema#>

SELECT ?name ?clearanceLevel ?doorsManaged
       (ROUND(?doorsManaged * 10000 / ?activeDoors) / 100 AS ?pctOfActiveFleet)
WHERE {
    ?tech a mi:DoorTechnician ;
          mi:name ?name ;
          mi:clearanceLevel ?clearanceLevel ;
          mi:doorsManaged ?doorsManaged .
    {
        SELECT (COUNT(?d) AS ?activeDoors)
        WHERE {
            ?d a mi:ChildDoor ;
               mi:doorStatus mi:active .
        }
    }
}
ORDER BY DESC(?doorsManaged) ?name


# Q22: Workforce wellbeing by dimension — aggregate pulse readings
# Business question: Across the wellbeing dimensions we track, what is the
#   average, lowest and highest pulse score, and how many readings fall below
#   the 5.0 support threshold per dimension?
# Returns: wellbeing dimension, reading count, avg / min / max score, count below 5.0
# Aggregates mi:WellbeingPulse by mi:wellbeingDimension — a portfolio view distinct
# from HC5 (per-worker rows < 5.0) and HC7 (the anti-stack-rank guardrail join).

PREFIX mi:   <https://vocab.monstersinc.com/ontology#>
PREFIX xsd:  <http://www.w3.org/2001/XMLSchema#>

SELECT ?dimension (COUNT(?pulse) AS ?readings)
       (ROUND(AVG(?score) * 100) / 100 AS ?avgScore)
       (MIN(?score) AS ?minScore) (MAX(?score) AS ?maxScore)
       (SUM(IF(?score < 5.0, 1, 0)) AS ?belowThreshold)
WHERE {
    ?pulse a mi:WellbeingPulse ;
           mi:wellbeingDimension ?dimension ;
           mi:pulseScore ?score .
}
GROUP BY ?dimension
ORDER BY ASC(?avgScore)
