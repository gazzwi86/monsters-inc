mi:Agent_MonstropolisGrid a prov:Agent ;
    rdfs:label "Monstropolis Power Grid Authority" .

mi:Agent_DoorVault a prov:Agent ;
    rdfs:label "Door Vault Management System" .

# ── Entities: Infrastructure ──────────────────────────────────────────────────

mi:LaughFloorStation_042 a mi:LaughFloorStation, prov:Entity ;
