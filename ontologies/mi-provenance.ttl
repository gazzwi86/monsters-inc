# ── Ontology Header ──────────────────────────────────────────────────────────

<https://vocab.monstersinc.com/provenance>
    a owl:Ontology ;
    rdfs:label "Monsters, Inc. Provenance — EnergyUnit EU-20240315-042-001" ;
    rdfs:comment "PROV-O instance file capturing the complete data lineage chain from child laughter capture through canister sealing and energy extraction to grid dispatch." ;
    owl:versionInfo "0.1.0" ;
    dct:creator "Monsters, Inc. Enterprise Architecture Team" ;
    dct:created "2024-03-15T10:26:00Z"^^xsd:dateTime .

# ── Agents ────────────────────────────────────────────────────────────────────

mi:Agent_Sulley a prov:Agent, mi:Comedian ;
